        insert into sys_role_menu(role_id, menu_id) values (1, menu_id);
        insert into sys_menu(name, parent_id, path, permission, type) values ('{{comment}}管理:更新', 0,'','{{module.name}}:{{biz}}:update','BUTTON') returning id into menu_id;
        insert into sys_role_menu(role_id, menu_id) values (1, menu_id);
        insert into sys_menu(name, parent_id, path, permission, type) values ('{{comment}}管理:删除', 0,'','{{module.name}}:{{biz}}:delete','BUTTON') returning id into menu_id;
        insert into sys_role_menu(role_id, menu_id) values (1, menu_id);
        insert into sys_menu(name, parent_id, path, permission, type) values ('{{comment}}管理:导出', 0,'','{{module.name}}:{{biz}}:export','BUTTON') returning id into menu_id;
        insert into sys_role_menu(role_id, menu_id) values (1, menu_id);
    end
$$;
